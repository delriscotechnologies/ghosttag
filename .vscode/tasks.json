{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ghosttag: test",
      "type": "shell",
      "command": "go",
      "args": ["test", "./..."],
      "options": {"cwd": "${workspaceFolder}"},
      "group": {"kind": "test", "isDefault": true},
      "problemMatcher": ["$go"]
    },
    {
      "label": "ghosttag: vet",
      "type": "shell",
      "command": "go",
      "args": ["vet", "./..."],
      "options": {"cwd": "${workspaceFolder}"},
      "problemMatcher": ["$go"]
    },
    {
      "label": "ghosttag: build Linux",
      "type": "shell",
      "command": "bash",
      "args": ["-lc", "mkdir -p bin && CGO_ENABLED=0 GOOS=linux go build -buildvcs=false -trimpath -o ./bin/ghosttag ./cmd/ghosttag"],
      "options": {"cwd": "${workspaceFolder}"},
      "group": {"kind": "build", "isDefault": true},
      "problemMatcher": ["$go"]
    }
  ]
}
